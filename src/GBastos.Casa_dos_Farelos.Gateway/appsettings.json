{
  
    "KeyVault": {
      "VaultUri": "https://seu-keyvault.vault.azure.net/"
    },
  "ReverseProxy": {

    "Routes": {

      "cadastro-br": {
        "ClusterId": "cadastro-br",
        "Match": {
          "Path": "/api/cadastro/{**catch-all}"
        },
        "Transforms": [
          {
            "RequestHeader": "X-Region",
            "Set": "BR"
          }
        ]
      },

      "cadastro-eu": {
        "ClusterId": "cadastro-eu",
        "Match": {
          "Path": "/eu/api/cadastro/{**catch-all}"
        }
      },

      "cadastro-af": {
        "ClusterId": "cadastro-af",
        "Match": {
          "Path": "/af/api/cadastro/{**catch-all}"
        }
      }

    },

    "Clusters": {

      "cadastro-br": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "br1": {
            "Address": "https://br1.casadosfarelos.internal/"
          },
          "br2": {
            "Address": "https://br2.casadosfarelos.internal/"
          }
        }
      },

      "cadastro-eu": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "eu1": {
            "Address": "https://eu1.casadosfarelos.internal/"
          }
        }
      },
      "cadastro-af": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "af1": {
            "Address": "https://af1.casadosfarelos.internal/"
          }
        }
      }

    }
  }
}